# V2Next dev env
# 由 dev.sh / scripts/lane-preflight.sh 自动 source。
# 手动调 sign.py 之前先 `source scripts/dev.env`。

# 屏幕保活时长（hdc 控制设备时使用）
export SCREEN_OFF_TIMEOUT_MS=13600000

# ── HarmonyOS 调试签名（账号级共享） ────────────────────────────────────────
# 物料目录：共享给多个 OH 项目以避免撞 AGC 调试证书配额。
# 文件结构：
#   $HARMONY_DEBUG_DIR/
#     ├── debug.p12              keystore（含密钥对）
#     ├── debug.csr              CSR
#     ├── ${HARMONY_DEBUG_CERT_NAME}.cer    AGC 签发的账号级 cert
#     └── profiles/
#         └── <bundleId>.p7b     per-project profile
#
# 注意 HARMONY_DEBUG_KS_ALIAS / KS_PWD 必须与 keystore 内部 alias/密码一致；
# 重命名 debug.p12 文件本身不会改 keystore 内 alias，未来如果重新生成
# keystore 才需要同步改这两个值。
#
# 签名物料锚定到真实用户 home，而不是 worker HOME。Kanban/profile workers
# 可能使用 sandbox HOME；这不能改变签名物料路径。只有真实账号 home 迁移时
# 才覆盖 V2NEXT_REAL_HOME。
export V2NEXT_REAL_HOME="${V2NEXT_REAL_HOME:-/home/gamer}"
export HARMONY_DEBUG_DIR="${V2NEXT_REAL_HOME}/.config/harmony/debug-signing"
export HARMONY_DEBUG_CERT_NAME="ohos-D"
export HARMONY_DEBUG_KS_ALIAS="ohos"
export HARMONY_DEBUG_KS_PWD="hw123456"

# 项目级 profile（per-bundleId，AGC 配额不限制 profile 数）
export HARMONY_DEBUG_PROFILE="${HARMONY_DEBUG_DIR}/profiles/com.next2v.app.p7b"
